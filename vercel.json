{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/index.js" },
    { "source": "/:path*\\.(css|js|png|jpg|jpeg|svg|ico|woff2|map)", "destination": "/public/:path*.$1" },
    { "source": "/:path*", "destination": "/public/index.html" }
  ],
  "functions": {
    "index.js": {
      "maxDuration": 60
    }
  }
}
