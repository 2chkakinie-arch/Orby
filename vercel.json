{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/index.js" },
    { "source": "/(.*\\.(css|js|png|jpg|jpeg|svg|ico|woff2|map))", "destination": "/public/$1" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "functions": {
    "index.js": {
      "maxDuration": 60
    }
  }
}
